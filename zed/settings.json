{
  // Themes
  "theme": {
    "mode": "system",
    "light": "GitHub Light Tritanopia",
    "dark": "GitHub Dark Dimmed",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },

  // Fonts
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 19.0,
  "buffer_font_size": 17.0,
  "agent_ui_font_size": 17.0,
  "agent_buffer_font_size": 17.0,

  // Titlebar
  "title_bar": {
    "show_branch_status_icon": true,
  },

  // Editor
  "colorize_brackets": true,
  "show_whitespaces": "trailing",
  "soft_wrap": "editor_width",

  // Editor Toolbar
  "toolbar": {
    "quick_actions": true,
    "selections_menu": false,
  },

  // Editor Tabs
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },

  // Edit Predictions
  "edit_predictions": {
    "mode": "subtle",
  },

  // Project Panel
  "project_panel": {
    "default_width": 500.0,
  },

  // Outline Panel
  "outline_panel": {
    "button": false,
  },

  // Agent Panel
  "agent": {
    "dock": "right",
    "sidebar_side": "right",
    "default_width": 500.0,
    "default_model": {
      "provider": "google",
      "model": "gemini-3-flash-preview",
    },
    "inline_assistant_model": {
      "provider": "google",
      "model": "gemini-3-flash-preview",
    },
    "commit_message_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
    },
  },
  "agent_servers": {
    "gemini": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "context_servers": {
    "chrome-devtools-mcp-zed": {
      "enabled": true,
      "remote": false,
      "settings": {
        "extra_args": ["--slim"],
      },
    },
    "mcp-server-context7": {
      "enabled": false,
      "remote": false,
      "settings": {},
    },
  },

  // Git Panel
  "git_panel": {
    "default_width": 500.0,
    "tree_view": true,
    "file_icons": true,
    "folder_icons": true,
  },

  // General
  "base_keymap": "VSCode",
  "autosave": "on_window_change",
  "profiles": {
    "presentation": {
      "settings": {
        "agent_ui_font_size": 28.0,
        "agent_buffer_font_size": 28.0,
        "buffer_font_size": 28.0,
      },
    },
  },
  "lsp": {
    "phpcs": {
      "settings": {
        "standard": "PSR4",
      },
    },
  },
  "languages": {
    "PHP": {
      "language_servers": ["intelephense", "phpcs", "!phpactor"],
      "format_on_save": "off",
    },
    "CSS": {
      "language_servers": [
        "tailwindcss-intellisense-css",
        "!vscode-css-language-server",
      ],
    },
    "XML": {
      "preferred_line_length": 120,
    },
    "YAML": {
      "format_on_save": "off",
    },
  },
  "file_types": {
    "JSON": ["*.tokens"],
    "HTML": ["*.vue", "*.twig", "*.njk"],
    "CSS": ["*.less"],
    "XML": ["*.svg"],
    "Markdown": ["llm.txt"],
    "Shell": ["Brewfile"],
  },
  "file_scan_exclusions": [
    // "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
  ],
  "auto_install_extensions": {
    // Themes
    "github-theme": true,
    "catppuccin-icons": true,
    // Languages
    "html": true,
    "php": true,
    "scss": true,
    "xml": true,
    "astro": true,
    "rainbow-csv": true,
    "comment": true,
    "editorconfig": true,
    // Languages Servers
    "phpcs": true,
    "emmet": true,
  },
}
