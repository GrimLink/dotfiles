[
  {
    "bindings": {
      "ctrl-alt-cmd-shift-s": [
        "workspace::MoveItemToPaneInDirection",
        { "direction": "right" },
      ],
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-alt-cmd-shift-p": "settings_profile_selector::Toggle",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-cmd-b": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-b": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "Editor && extension == md",
    "bindings": {
      "cmd-b": [
        "editor::InsertSnippet",
        { "name": "Markdown bold", "language": "markdown" },
      ],
      "cmd-i": [
        "editor::InsertSnippet",
        { "name": "Markdown italic", "language": "markdown" },
      ],
    },
  },
]
