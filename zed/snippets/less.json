{
  "background": {
    "prefix": "background",
    "description": "Short hand background",
    "body": "background: ${1:transparent} ${2:/* img */} ${3:center/contain} ${4:no-repeat};"
  },
  "Less foreach": {
    "prefix": "foreach",
    "description": "Less foreach mixin",
    "body": [
      ".each-${1:name}(length(${1:@name}));",
      ".each-${1:name}(@n, @i: 0) when (@i <= @n) {",
      "\t${2:@value}: extract(@name, @i);",
      "\t${3:prop}: ${2:@value};\n\t",
      "\t.each-$1(@n, (@i + 1)); // iterator\n}"
    ]
  },
  "Less if": {
    "prefix": "if",
    "description": "if statment (less mixin guard)",
    "body": ["& when (${1:@var}) {", "\t$0", "}"]
  }
}
