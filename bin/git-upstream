#!/bin/bash

URL="${1}"
NAME="${2}"

if [[ -z "$URL" ]]; then
  read -p "Remote url: " URL
  echo ""
  if [[ -z "$URL" ]]; then exit; fi
fi

if [[ -z "$NAME" ]]; then
  DEFAULT_NAME=$(echo "$URL" | awk -F'/' '{print $(NF-1)}')
  read -p "Remote name [$DEFAULT_NAME]: " NAME
  echo ""
  NAME="${NAME:-$DEFAULT_NAME}"
  if [[ -z "$NAME" ]]; then exit; fi
fi

git remote add "$NAME" "$URL"
