#!/bin/bash

# Create new git ENV and pushes it to a new repo
GITURL="${1}"

git init
git add .
git commit -m 'initial commit of full repository'

if [[ -z "$GITURL" ]]; then
  read -p "Git repo URL: " GITURL
  echo ""
  if [[ -z "$GITURL" ]]; then exit; fi
fi

git remote add origin "$GITURL" && git push -u origin --all
